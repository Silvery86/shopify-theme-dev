{{ 'all-products.css' |  asset_url |  stylesheet_tag }}

{% assign sorted_products = collections.all.products %}

{%- comment -%}
  Only sort keys that map to real Product properties work here. Best-selling /
  sale-percent / sold-number are not array-sortable in Liquid, so they are not
  offered as options (they would silently be no-ops).
{%- endcomment -%}
{%- case section.settings.product_sort_by -%}
  {%- when 'newest' -%}
    {%- assign sorted_products = sorted_products | sort: 'created_at' | reverse -%}
  {%- when 'price_low_to_high' -%}
    {%- assign sorted_products = sorted_products | sort: 'price' -%}
  {%- when 'price_high_to_low' -%}
    {%- assign sorted_products = sorted_products | sort: 'price' | reverse -%}
{%- endcase -%}

{%- comment -%}
  Build the comma-separated handle list of products that come AFTER the first
  row (which is rendered server-side below); the JS load-more button fetches
  these on demand.
{%- endcomment -%}
{%- assign remaining_products = '' -%}
{%- for product in sorted_products offset: section.settings.products_per_row -%}
  {%- if forloop.first -%}
    {%- assign remaining_products = product.handle -%}
  {%- else -%}
    {%- assign remaining_products = remaining_products | append: ',' | append: product.handle -%}
  {%- endif -%}
{%- endfor -%}



<div class="page-width" id="{{ section.id }}">
  <div style="text-align: {{ section.settings.text_alignment }};">
    <h2>{{ section.settings['all-product-header'] }}</h2>
    <p>{{ section.settings['all-product-subtitle'] }}</p>
  </div> 
  <all-products
    data-remaining-products="{{ remaining_products }}"
    data-products-per-row="{{ section.settings.products_per_row }}"
  >  
    <div
      class="grid"
      style="--item-per-row: {{ section.settings.products_per_row }}"
    >
      {% for product in sorted_products limit: section.settings.products_per_row %}
        {% render 'card-product', card_product: product %}
      {% endfor %}
    </div>
    <button class="button">Load More</button>
  </all-products>
</div>

<script src="{{ 'all-products.js' |  asset_url }}" async></script>

{% schema %}
{
  "name": "All Products",
  "disabled_on": {
    "groups": ["header","footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "All Product Settings"
    },
    {
      "type": "text",
      "id" : "all-product-header",
      "label" : "Heading Text"
    },
    {
      "type": "richtext",
      "id" : "all-product-subtitle",
      "label" : "Subtitle Text"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Products Settings"
    },
    {
      "type": "number",
      "id": "products_per_row",
      "label": "Product Per Row",
      "default": 4
    },
    {
  "type": "select",
  "id": "product_sort_by",
  "label": "Sort Products By",
  "options": [
    {
      "value": "newest",
      "label": "Newest"
    },
    {
      "value": "price_low_to_high",
      "label": "Price, Low to High"
    },
    {
      "value": "price_high_to_low",
      "label": "Price, High to Low"
    }
  ],
  "default": "price_low_to_high"
}

  ],
  "presets": [
    {
      "name": "All Products"
    }
  ]
}
{% endschema %}
