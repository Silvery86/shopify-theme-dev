{% comment %}
  Renders a single product card for home page.
  Expected input: product (Product object)
  Requires 'custom-product-card.css' and 'product-fake-rating.css' to be
  loaded once by the parent section (do not load stylesheets inside this
  snippet — it is rendered inside a loop).
{% endcomment %}
<div class="custom-products__item">
  <div class="custom-products__card">
    <div class="custom-products__image-wrapper">
      <a href="{{ product.url }}">
        <img
          src="{{ product.featured_image | image_url: width: 400 }}"
          alt="{{ product.title }}"
          width="400"
          height="400"
          loading="lazy"
        >
      </a>
    </div>
    <div class="custom-products__info">
      <div class="custom-products__content">
        {% render 'product-rating', product: product %}
        <h3>
          <a href="{{ product.url }}">
            {{ product.title }}
          </a>
        </h3>
      </div>
      <div class="custom-product__cart-price">
        <div class="custom-product__price">
          <span class="price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="price--sale">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </div>
        <div class="custom-product__cart">
          <form method="post" action="{{ routes.cart_add_url }}" data-custom-add-to-cart>
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit" aria-label="Add to cart">
              {% render 'icon-cart' %}
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
